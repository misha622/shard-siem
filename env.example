# SHARD Enterprise — Environment Variables
# Copy to .env and fill in your values

# REQUIRED FOR PRODUCTION
SHARD_CONFIG_SECRET=generate_with_python_secrets_token_hex_32
SHARD_PRODUCTION=true

# Dashboard
SHARD_DASHBOARD_USERNAME=admin
SHARD_DASHBOARD_PASSWORD=change_me_immediately

# Database (optional)
SHARD_PG_DSN=postgresql://shard:password@localhost:5432/shard_siem

# Threat Intelligence APIs
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# Redis Cluster (optional)
SHARD_REDIS_URL=redis://localhost:6379

# GPU (optional)
SHARD_USE_GPU=false
