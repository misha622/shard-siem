# SHARD Enterprise SIEM - Переменные окружения
# Скопируйте в .env и заполните своими значениями

# Dashboard
SHARD_DASHBOARD_USERNAME=admin
SHARD_DASHBOARD_PASSWORD=change_me_in_production

# Threat Intelligence
ABUSEIPDB_KEY=
VIRUSTOTAL_KEY=
IPINFO_TOKEN=

# Cloud (AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cloud (Azure)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Cloud (GCP)
GCP_PROJECT_ID=
GCP_CREDENTIALS_FILE=

# Federated Learning
FEDERATED_SERVER_AUTH_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LDAP
LDAP_BIND_PASSWORD=

# Config signing
SHARD_CONFIG_SECRET=
SHARD_PRODUCTION=false
